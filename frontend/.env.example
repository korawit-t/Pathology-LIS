# =================================================================
# FRONTEND CONFIGURATION (Vite)
# =================================================================
# ⚠️ All variables MUST be prefixed with VITE_ to be exposed to the browser.

# URL of the backend API that the frontend calls.
# Must be reachable from the user's browser — use a real IP or domain,
# NOT "localhost" when the frontend is served from a remote server.

# Local development:
# VITE_API_BASE_URL=http://localhost:8000

# LAN / home server (replace with your server's IP):
VITE_API_BASE_URL=http://192.168.1.100:8000

# Production / cloud (domain or public IP):
# VITE_API_BASE_URL=https://api.yourdomain.com

# Railway (or any cloud host) WITHOUT a custom domain — build with
# Dockerfile.railway instead of Dockerfile. That build serves frontend +
# proxies API calls through the same nginx (see nginx.railway.conf.template),
# so the API is same-origin. Leave this EMPTY in that case (relative calls),
# not the backend's own *.up.railway.app URL — using an absolute
# cross-origin URL there is exactly what breaks the auth cookie in Safari.
# VITE_API_BASE_URL=
