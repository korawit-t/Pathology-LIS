# =================================================================
# FRONTEND CONFIGURATION (Vite)
# =================================================================
# ⚠️ All variables MUST be prefixed with VITE_ to be exposed to the browser.

# URL of the backend API that the frontend calls.
# Must be reachable from the user's browser — use a real IP or domain,
# NOT "localhost" when the frontend is served from a remote server.

# Local development:
# VITE_API_BASE_URL=http://localhost:8000

# LAN / home server (replace with your server's IP):
VITE_API_BASE_URL=http://192.168.1.100:8000

# Production / cloud (domain or public IP):
# VITE_API_BASE_URL=https://api.yourdomain.com
