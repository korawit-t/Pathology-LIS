# =================================================================
# ENVIRONMENT
# =================================================================
# Controls Secure-cookie flag, strict CORS validation, and whether
# /docs / /redoc / /openapi.json are served.
#
# "development" — plain HTTP cookies, Swagger UI enabled
# "production"  — Secure cookies, strict CORS, no public Swagger
#
# Default (unset) = "production". Fail-closed by design.
# The dev docker-compose.override.yml sets ENVIRONMENT=development automatically.
# Uncomment the line below ONLY in a local dev environment:
# ENVIRONMENT=development

# =================================================================
# DATABASE CONFIGURATION
# =================================================================
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:5432/DB_NAME
# In Docker use the service name 'db' instead of localhost.
# After first-time setup, switch to the least-privilege role:
#   DATABASE_URL=postgresql+psycopg2://lis_app_rw:<LIS_APP_PASSWORD>@db:5432/<POSTGRES_DB>
DATABASE_URL=postgresql+psycopg2://lisuser:CHANGE_ME@db:5432/pathology_lis

# =================================================================
# SECURITY & AUTHENTICATION
# =================================================================
# REQUIRED — generate with: openssl rand -hex 32
# The server will refuse to start if this is missing, shorter than 32 chars,
# or still set to this placeholder value.
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=3

# =================================================================
# CORS & NETWORK
# =================================================================
# Comma-separated list of allowed frontend origins.
# Add every IP/hostname that will access the API.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://192.168.1.100:3000

# IP/CIDR of your reverse proxy (nginx, Traefik, Caddy, etc.).
# Used to validate X-Forwarded-For — prevents IP spoofing in audit logs.
# Use "127.0.0.1" if the proxy runs on the same host. Comma-separate multiple entries.
TRUSTED_PROXY_IPS=127.0.0.1

# =================================================================
# HIS INTEGRATION (Hospital Information System)
# =================================================================
# Set HIS_TYPE to the HIS vendor your hospital uses.
# Currently supported: "hosxp"  |  Leave blank to disable HIS integration.
HIS_TYPE=hosxp

# Connection string for the HIS database (read-only recommended).
# Format: mysql+pymysql://USER:PASSWORD@HOST:3306/DB_NAME?charset=utf8
HIS_DATABASE_URL=mysql+pymysql://lisuser:password@192.168.1.200:3306/hos?charset=utf8

# HOSxP order-form names used to match incoming orders to case types.
# Change these to match the exact form names configured in your HOSxP instance.
HOSXP_FORM_SURGICAL=Pathology
HOSXP_FORM_GYNE=PAP smear, liquid based cytology and HPV testing
HOSXP_FORM_NONGYNE=FNA, Body fluid cytology

# =================================================================
# AI / LLM INTEGRATION (Optional)
# =================================================================
# API keys per provider — stored here only, never in the database.
# LLM profiles (name, model, base_url) are configured via System Settings UI.
# Leave blank to disable AI features for that provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_COMPATIBLE_API_KEY=   # Azure OpenAI, Gemini, Ollama, or any OpenAI-compatible endpoint

# =================================================================
# GOOGLE CALENDAR INTEGRATION (Optional)
# =================================================================
# Used for Pathologist schedule / holiday sync.
# Leave blank to disable.
GOOGLE_CALENDAR_API_KEY=


# =================================================================
# BACKUP CONFIGURATION (Optional)
# =================================================================
# Slack Incoming Webhook URL for backup success/failure notifications.
# Leave blank to disable Slack alerts.
SLACK_BACKUP_WEBHOOK=

# Root directory where backup files are written.
# Windows example: D:\pathology_backup
# Linux example:   /media/ubuntu/PATHOLOGY_BK/pathology_backup
BACKUP_ROOT=

# (Windows only) Full path to the PostgreSQL bin folder containing pg_dump.exe
# Not needed on Linux/Docker — pg_dump runs inside the container.
# Example: C:\Program Files\PostgreSQL\15\bin
BACKUP_PG_BIN=

# (Linux/Docker only) Name of the Docker container running PostgreSQL.
# Defaults to "pathology-db" if not set.
# DB_CONTAINER=pathology-db

# Path to the uploaded files directory (images, attachments, etc.)
# Defaults to backend\uploads (Windows) or backend/uploads (Linux) if not set.
# STORAGE_DIR=C:\New LIS\Pathology_LIS\backend\uploads

# หมายเหตุ: backup ทับไฟล์เดิมทุกคืน (db_latest.dump / storage_latest.zip)
# ไม่มีการเก็บหลายเวอร์ชัน เพื่อประหยัด HDD
