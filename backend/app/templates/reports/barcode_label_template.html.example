<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <style>
      @font-face {
        font-family: "Sarabun";
        src: url("{{ font_path | safe }}/Sarabun-Regular.ttf");
        font-weight: 400;
      }
      @font-face {
        font-family: "Sarabun";
        src: url("{{ font_path | safe }}/Sarabun-Bold.ttf");
        font-weight: 700;
      }
      @page {
        size: A4;
        margin: 10mm 10mm;
      }
      body {
        font-family: "Sarabun", sans-serif;
        margin: 0;
        padding: 0;
        color: #1a202c;
        font-size: 11px;
      }

      .label-grid {
        width: 100%;
      }

      .label-card {
        border: 1px dashed #cbd5e1;
        padding: 10px 14px;
        margin-bottom: 8px;
        page-break-inside: avoid;
      }

      .label-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
        border-bottom: 1px solid #e2e8f0;
        padding-bottom: 4px;
      }

      .accession {
        font-size: 14px;
        font-weight: 700;
        color: #0056b3;
      }

      .patient-info {
        font-size: 10px;
        color: #475569;
        margin-bottom: 6px;
      }

      .patient-name {
        font-weight: 700;
        font-size: 12px;
        color: #1e293b;
      }

      .barcode-area {
        text-align: center;
        margin: 6px 0;
      }

      .barcode-area svg {
        max-width: 280px;
        height: 50px;
      }

      .barcode-text {
        font-size: 11px;
        font-weight: 700;
        text-align: center;
        color: #1a202c;
        letter-spacing: 1.5px;
        margin-top: 2px;
      }

      .barcode-type-label {
        font-size: 8px;
        color: #94a3b8;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: 1px;
      }
    </style>
  </head>
  <body>
    <div class="label-grid">
      {% for item in labels %}
      <div class="label-card">
        <table style="width: 100%; border-collapse: collapse;">
          <tr>
            <td style="vertical-align: top; width: 45%;">
              <div class="accession">{{ item.accession_no }}</div>
              <div class="patient-name">{{ item.patient_title or '' }}{{ item.patient_name }}{% if item.patient_ln %} {{ item.patient_ln }}{% endif %}</div>
              <div class="patient-info">
                HN: <b>{{ item.patient_hn }}</b> |
                {{ item.patient_gender }} |
                Age: {{ item.patient_age_display or item.patient_age }}
              </div>
              <div class="patient-info">
                Hospital: {{ item.hospital_name or '-' }}
              </div>
            </td>
            <td style="vertical-align: middle; text-align: center; width: 55%;">
              <div class="barcode-area">
                <img src="{{ item.barcode_svg | safe }}" style="width: 100%;">
              </div>
              <div class="barcode-text">{{ item.barcode_value }}</div>
              <div class="barcode-type-label">{{ item.barcode_type }}</div>
            </td>
          </tr>
        </table>
      </div>
      {% endfor %}
    </div>
  </body>
</html>
