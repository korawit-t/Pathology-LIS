backend/data/*.sql
# Report templates are tracked directly as .html files
# Hospital-specific overrides go in local/ — NOT tracked (only .gitkeep is tracked)
backend/app/templates/reports/local/*.html
# หากมีไฟล์ที่สร้างจาก Alembic แต่ต้องการล้างประวัติ
